// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  user
  company
}

enum ProjectStatus {
  recruiting
  proposed
  interviewing
  contracted
  closed
}

enum EngineerStatus {
  available
  proposed
  working
  inactive
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(user)

  companyName String?
  isBpCompany Boolean @default(false)

  projects          Project[]         @relation("UserProjects")
  engineers         Engineer[]        @relation("UserEngineers")
  proposalHistories ProposalHistory[] @relation("UserProposalHistories")
  workRecords       WorkRecord[]      @relation("UserWorkRecords")
  bpCompanies       BpCompany[]       @relation("UserBpCompanies")

  bpCompanyId String?
  bpCompany   BpCompany? @relation("BpCompanyUsers", fields: [bpCompanyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String
  location    String
  unitPrice   Int
  status      ProjectStatus @default(recruiting)

  createdById String
  createdBy   User   @relation("UserProjects", fields: [createdById], references: [id])

  skills            Skill[]           @relation("ProjectSkills")
  proposalHistories ProposalHistory[]
  workRecords       WorkRecord[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Skill {
  id       String @id @default(cuid())
  name     String
  category String

  projects  Project[]  @relation("ProjectSkills")
  engineers Engineer[] @relation("EngineerSkills")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name, category])
}

model Engineer {
  id          String @id @default(cuid())
  name        String
  companyName String

  bpCompanyId String?
  bpCompany   BpCompany? @relation("BpCompanyEngineers", fields: [bpCompanyId], references: [id])

  age               Int?
  gender            String?
  nearestStation    String?
  desiredUnitPrice  Int?
  experienceYears   Int?
  availableDate     DateTime?
  desiredLocation   String?
  desiredConditions String?
  careerSummary     String?
  status            EngineerStatus @default(available)

  createdById String
  createdBy   User   @relation("UserEngineers", fields: [createdById], references: [id])

  skills            Skill[]           @relation("EngineerSkills")
  proposalHistories ProposalHistory[]
  workRecords       WorkRecord[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ProposalHistory {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  engineerId String
  engineer   Engineer @relation(fields: [engineerId], references: [id])

  status        ProposalStatus @default(proposed)
  proposedAt    DateTime       @default(now())
  interviewDate DateTime?
  memo          String?

  createdById String
  createdBy   User   @relation("UserProposalHistories", fields: [createdById], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model WorkRecord {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  engineerId String
  engineer   Engineer @relation(fields: [engineerId], references: [id])

  targetMonth   String
  workingHours  Int
  billingAmount Int
  paymentAmount Int
  grossProfit   Int
  memo          String?

  createdById String
  createdBy   User   @relation("UserWorkRecords", fields: [createdById], references: [id])

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum ProposalStatus {
  proposed
  interviewing
  accepted
  rejected
  withdrawn
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model BpCompany {
  id String @id @default(cuid())

  name          String
  joinCode      String  @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  memo          String?

  createdById String
  createdBy   User   @relation("UserBpCompanies", fields: [createdById], references: [id])

  users     User[]     @relation("BpCompanyUsers")
  engineers Engineer[] @relation("BpCompanyEngineers")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name])
}
